{
  "name": "randomware",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "format:check": "node scripts/check-format.js",
    "lint": "node scripts/check-lint.js",
    "typecheck": "node scripts/check-types.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "test:e2e:deployed": "node scripts/test-deployed.js",
    "test:e2e:synthetic": "node scripts/test-synthetic-deployed.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "build": "node scripts/build.js",
    "dev": "node src/server.js",
    "dev:worker": "node scripts/dev-worker.js",
    "deploy": "npx --yes wrangler deploy",
    "db:migrate": "npx --yes wrangler d1 migrations apply randomware",
    "registry:verify": "node scripts/registry-verify.js",
    "registry:adapt": "node scripts/adapt-fixtures.js",
    "registry:adapt:live": "node scripts/recapture-adapted-live.js",
    "registry:contracts": "node scripts/generate-response-contracts.js",
    "registry:verify:live": "node scripts/registry-live.js",
    "registry:health:publish": "node scripts/registry-health-publish.js",
    "feasibility:local": "node scripts/feasibility-local.js",
    "security:scan": "node scripts/security-scan.js",
    "secrets:scan": "node scripts/secrets-scan.js",
    "documents:check": "node scripts/document-check.js",
    "acceptance:machine": "node scripts/acceptance-machine.js"
  }
}
